{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build/client" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": ["build/server/**", "public/**"]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}

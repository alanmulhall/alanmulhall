<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Admin – Alan Mulhall</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta21/dist/css/tabler.min.css" />
  </head>
  <body class="antialiased">
    <div class="wrapper">
      <header class="navbar navbar-expand-md navbar-light d-print-none">
        <div class="container-xl">
          <a href="/admin/images" class="navbar-brand">
            <span class="fw-bold">Alan Mulhall</span>
            <span class="text-muted ms-2">Admin</span>
          </a>
        </div>
      </header>

      <div class="page-wrapper">
        <div class="page-header d-print-none">
          <div class="container-xl">
            <div class="row g-2 align-items-center">
              <div class="col">
                <h2 class="page-title"><%= content_for?(:page_title) ? yield(:page_title) : "Images" %></h2>
              </div>
              <% if content_for?(:page_action) %>
                <div class="col-auto ms-auto"><%= yield(:page_action) %></div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="page-body">
          <div class="container-xl">
            <% if notice %>
              <div class="alert alert-success alert-dismissible mb-3" role="alert">
                <%= notice %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>
            <%= yield %>
          </div>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta21/dist/js/tabler.min.js"></script>
  </body>
</html>

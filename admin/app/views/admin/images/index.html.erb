<% content_for :page_title, "Images" %>
<% content_for :page_action do %>
  <%= link_to "Add image", new_admin_image_path, class: "btn btn-dark" %>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-vcenter card-table">
      <thead>
        <tr>
          <th style="width: 80px">Order</th>
          <th style="width: 100px">Thumbnail</th>
          <th>Title</th>
          <th>Kind</th>
          <th>Medium</th>
          <th>Dimensions</th>
          <th>Year</th>
          <th>Visible</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @images.each do |image| %>
          <tr>
            <td>
              <div class="d-flex flex-column gap-1">
                <%= button_to "↑", move_up_admin_image_path(image), method: :patch,
                    class: "btn btn-sm btn-ghost-secondary px-2 py-0",
                    disabled: image.position == @images.first.position %>
                <span class="text-center text-muted small"><%= image.position %></span>
                <%= button_to "↓", move_down_admin_image_path(image), method: :patch,
                    class: "btn btn-sm btn-ghost-secondary px-2 py-0",
                    disabled: image.position == @images.last.position %>
              </div>
            </td>
            <td>
              <% if image.cloudinary_public_id %>
                <img src="<%= image.thumbnail_url %>" alt="<%= image.title %>"
                     style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px; cursor: pointer;"
                     data-bs-toggle="modal" data-bs-target="#image-modal"
                     data-src="<%= image.display_url %>" data-title="<%= image.title %>" />
              <% end %>
            </td>
            <td class="fw-medium"><%= image.title %></td>
            <td class="text-muted"><%= image.kind&.capitalize %></td>
            <td class="text-muted"><%= image.medium %></td>
            <td class="text-muted"><%= image.dimensions %></td>
            <td class="text-muted"><%= image.year %></td>
            <td>
              <% if image.visible? %>
                <span class="badge bg-success-lt">Yes</span>
              <% else %>
                <span class="badge bg-secondary-lt">No</span>
              <% end %>
            </td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_image_path(image), class: "btn btn-sm btn-ghost-secondary" %>
              <%= button_to "Delete", admin_image_path(image), method: :delete,
                  class: "btn btn-sm btn-ghost-danger",
                  data: { confirm: "Delete \"#{image.title}\"?" } %>
            </td>
          </tr>
        <% end %>
        <% if @images.empty? %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">No images yet. Add one to get started.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal modal-blur fade" id="image-modal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="image-modal-title"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0 text-center">
        <img id="image-modal-img" src="" alt="" style="max-width: 100%; max-height: 80vh; object-fit: contain;" />
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('image-modal').addEventListener('show.bs.modal', function(event) {
    var img = event.relatedTarget;
    document.getElementById('image-modal-img').src = img.dataset.src;
    document.getElementById('image-modal-title').textContent = img.dataset.title;
  });
</script>
